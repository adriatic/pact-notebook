{
  "name": "pact",
  "displayName": "PACT",
  "description": "PACT Notebook Environment",
  "version": "0.0.1",
  "publisher": "pact",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  
  "contributes": {
    "commands": [
      {
        "command": "pact.open",
        "title": "PACT: Open"
      }
    ]
  },

  "scripts": {
    "compile": "tsc -p tsconfig.json && tsc -p tsconfig.ui.json",
    "watch": "tsc -w -p tsconfig.json",
    "watch:ui": "tsc -w -p tsconfig.ui.json"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.0.0"
  }
}