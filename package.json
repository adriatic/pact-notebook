{
  "name": "pact",
  "displayName": "PACT",
  "description": "PACT Notebook Environment",
  "version": "0.0.1",
  "publisher": "pact",

  "engines": {
    "vscode": "^1.85.0"
  },

  "categories": ["Other"],

  "main": "./out/extension.js",

  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pact",
          "title": "PACT",
          "icon": "media/pact.svg"
        }
      ]
    },

    "views": {
      "pact": [
        {
          "id": "pactExplorer",
          "name": "NOTEBOOKS",
          "icon": "media/pact.svg"
        },
        {
          "id": "pact.controlPanel",
          "name": "CONTROL",
          "type": "webview",
          "icon": "media/pact.svg"
        }
      ]
    },

    "commands": [
      {
        "command": "pact.copyPrompt",
        "title": "Copy Prompt"
      }
    ]
  },

  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },

  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.0.0"
  }
}