{
  "name": "pact-notebook",
  "displayName": "PACT Notebook",
  "description": "PACT AI Notebook",
  "version": "0.0.1",
  "publisher": "pact",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/notebooks",
    "onCommand:pact.runCell"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pact.runCell",
        "title": "PACT: Run Cell"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "pact.controlPanel",
          "name": "PACT Control",
          "type": "webview",
          "icon": "media/pact.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.18.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}